<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/surah_widget_background"
    android:paddingStart="13dp"
    android:paddingTop="11dp"
    android:paddingEnd="13dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/widget_ready_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◐  Surah Planner"
            android:textColor="#7AFFFFFF"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_current_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DHUHR"
                android:textAllCaps="true"
                android:textColor="#D4AF37"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="#61FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_current_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#E6FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_current_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_current_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_current_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6FFFFFF"
            android:textSize="10sp" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/surah_widget_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_next_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ASR"
                android:textAllCaps="true"
                android:textColor="#6BFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="in 2h30"
                android:textColor="#42FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_next_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_next_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_next_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_next_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_empty_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◐"
            android:textColor="#29FFFFFF"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/widget_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D9FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_empty_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8CFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
